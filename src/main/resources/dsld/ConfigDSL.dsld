	@Override
	String toString() { 
		return "DSLClass: ${type?.name}"
	}

    boolean isFinal() {
        return (type?.modifiers & Opcodes.ACC_FINAL) != 0
    }

    boolean isAbstract() {
        return (type.modifiers & Opcodes.ACC_ABSTRACT) != 0
    }

}
